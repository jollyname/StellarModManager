<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StellarModManager.ViewModels"
             xmlns:loc="using:StellarModManager.Services"
             x:Class="StellarModManager.Views.OnlineModsView"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*" Margin="0,16,0,0">
        <Grid Grid.Row="0" Margin="0,0,0,14" ColumnDefinitions="*,Auto">
            <TextBlock
                Grid.Column="0"
                Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[OnlineModsDescription]}"
                FontSize="13"
                Foreground="{DynamicResource Theme.TextSecondaryBrush}"
                VerticalAlignment="Center"/>
            <Button
                Grid.Column="1"
                Classes="secondary"
                Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Refresh]}"
                Command="{Binding RefreshModsCommand}"/>
        </Grid>
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding OnlineMods}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="modCard">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Theme.TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Version}" FontSize="12" Foreground="{DynamicResource Theme.AccentEndBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Author}" FontSize="12" Foreground="{DynamicResource Theme.TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="13" TextWrapping="Wrap" Foreground="{DynamicResource Theme.TextPrimaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button
                                        Grid.Column="1"
                                        Classes="secondary"
                                        Content="{Binding InstallButtonText}"
                                        VerticalAlignment="Top"
                                        IsVisible="{Binding !IsInstalling}"
                                        Command="{Binding $parent[UserControl].DataContext.InstallModCommand}"
                                        CommandParameter="{Binding}"/>
                                </Grid>
                                <StackPanel IsVisible="{Binding IsInstalling}" Spacing="4">
                                    <ProgressBar Classes="modProgress" Minimum="0" Maximum="100" Value="{Binding DownloadProgress}"/>
                                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Installing]}" FontSize="11" Foreground="{DynamicResource Theme.TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>